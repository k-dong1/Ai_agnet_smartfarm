SMARTFARM_API_SERVICE_KEY=YOUR_SMARTFARM_API_SERVICE_KEY_HERE
PEST_API_SERVICE_KEY=YOUR_PEST_API_SERVICE_KEY_HERE
DATA_GO_KR_SERVICE_KEY=YOUR_DATA_GO_KR_SERVICE_KEY_HERE
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
REQUEST_TIMEOUT=90

# --- Location & Period Configuration ---
# Number of days to collect weather data for training (e.g. 14 or 30 days)
WEATHER_DATA_DAYS=30

# Specific weather station code or name (e.g., 477802A001 for Gapyeong-eup)
# If left blank, it will parse all collected stations.
TARGET_STATION_CODE=477802A001
TARGET_STATION_NAME=가평군 가평읍

# Specific Smart Farm facility ID
TARGET_FARM_ID=M2103_001_001_01